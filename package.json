{
  "name": "decision-journal",
  "productName": "Decision Journal",
  "version": "1.0.0",
  "description": "A desktop application for tracking decisions.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "postinstall": "node scripts/patch-electron.js"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.laike9m.decisionjournal",
    "icon": "assets/app_icon.png",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "icon/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "puppeteer": "^24.41.0",
    "ws": "^8.20.0"
  }
}
